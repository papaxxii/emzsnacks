//firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public snacks collection: anyone can read, only authenticated users can write (vendors/admins should be constrained server-side)
    match /snacks/{snackId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid != null && request.auth.token.email_verified == true;
    }

    // Orders: only authenticated users can create orders; users can read their own orders
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Users: users can read/write their own profile; admins must be set via secure server or console
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // For any other documents deny by default
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
